# The port the application will listen on (default is 8080)
PORT=8080

# GitHub Personal Access Token (PAT) used for whitelisted users
# No special scopes/permissions are needed for public stats.
GITHUB_TOKEN=your_github_token_here

# Comma-separated list of usernames that are allowed to use the GITHUB_TOKEN.
# All other users must pass their own token via the "Authorization" header.
WHITELIST=
